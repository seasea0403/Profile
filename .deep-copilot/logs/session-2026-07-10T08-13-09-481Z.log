n class=\"modal-close\" onclick=\"closeAbout()\">✕</button>\n    <h3 style=\"margin-bottom:16px;\">ABOUT 关于我</h3>\n    <p>专注游戏世界观、环境概念设计与电影化视觉开发。擅长结合二维概念与三维引擎，打造具备完整叙事氛围的空间场景。</p>\n    <p style=\"margin-top:14px;color:#aaa;\">\n      邮箱：2194733118@qq.com<br>\n      微信：Lin_Ran-7<br>\n      可咨询全职岗位、外包场景、概念设计、美术合作项目\n    </p>\n  </div>\n</div>\n\n<script>\n// ===== 项目数据 =====\n// playUrl: 填入 WebGL / HTML5 游戏链接即可启用\"可玩原型\"按钮\n//   例如 Unity WebGL: \"play/ld59/index.html\"\n//   例如 itch.io 嵌入: \"https://yourname.itch.io/gamename\"\n//   留空 \"\" 则不显示按钮\nconst projects = [\n  {\n    id: 'ld59',\n    name: 'Ludum Dare 59',\n    tag: 'Game Jam / 叙事 / 跑酷',\n    desc: '参加 Ludum Dare 59 全球游戏创作大赛，在 72 小时内从零完成的一款小型叙事跑酷游戏。结合跑酷玩法与碎片化叙事，玩家在奔跑中逐步拼凑出完整的故事。',\n    highlight: '在 1000+ 参赛作品中排名第 38 名',\n    cover: 'covers/ld59.jpg',\n    engine: 'Unity',\n    color: '#f97316',\n    screenshots: 3,\n    playUrl: '',\n  },\n  {\n    id: 'fireworks',\n    name: '岁岁烟火铺',\n    tag: '模拟经营 / 江西烟花 / 文旅合作',\n    desc: '以江西烟花文化为背景的模拟经营游戏。玩家经营一间烟火铺子，从选料配比到燃放编排，体验传统烟花制作的完整工艺流程。融入江西地域文化元素与节庆氛围。',\n    highlight: '与当地文旅局达成合作，合作金额达 10 万元',\n    cover: 'covers/fireworks.jpg',\n    engine: 'Unity',\n    color: '#ef4444',\n    screenshots: 4,\n    playUrl: '',\n  },\n  {\n    id: 'tide',\n    name: '潮痕',\n    tag: 'Godot / 2D / 探索解谜',\n    desc: '使用 Godot 引擎开发的 2D 探索解谜游戏。以「潮汐」为核心机制——潮水涨落改变场景地形，玩家需要观察水位规律、寻找隐藏路径，逐步揭开被海水淹没的遗迹之谜。',\n    highlight: '独立探索解谜，潮汐机制驱动关卡变化',\n    cover: 'covers/tide.jpg',\n    engine: 'Godot',\n    color: '#06b6d4',\n    screenshots: 4,\n    playUrl: '',\n  },\n  {\n    id: 'canteen',\n    name: '灵啵食堂',\n    tag: 'Unity / UGF / 模拟经营',\n    desc: '基于 Unity 与 GameFramework（UGF）框架开发的 2D 模拟经营游戏。核心玩法围绕菜品制作展开——从食材采购、加工工位调度到烹饪出餐，玩家需要管理完整的后厨流水线。',\n    highlight: '基于 UGF 框架的完整商业级项目架构',\n    cover: 'covers/canteen.jpg',\n    engine: 'Unity',\n    color: '#10b981',\n    screenshots: 4,\n    playUrl: '',\n  },\n];\n\nlet activeProjectId = null;\n\n// ===== 生成磁带 =====\nconst rack = document.getE