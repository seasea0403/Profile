[2026-07-10T11:14:56.050Z] [TOOL_CALL] {"id":"call_00_b5cZ9PoRX7YdOqNPLp1e3299","name":"str_replace_in_file","args":{"new_string":"function openPlay(projectId, mode = 'game') {\n  const project = projects.find(p => p.id === projectId);\n  if (!project) return;\n\n  const overlay = document.getElementById('playOverlay');\n  const body = document.getElementById('playBody');\n  const title = document.getElementById('playTitle');\n\n  let content = '';\n\n  if (mode === 'video' && project.videoUrl) {\n    const url = project.videoUrl;\n    // YouTube\n    if (url.includes('youtube.com') || url.includes('youtu.be')) {\n      let embedUrl = url;\n      if (url.includes('watch?v=')) {\n        embedUrl = url.replace('watch?v=', 'embed/').split('&')[0];\n      } else if (url.includes('youtu.be/')) {\n        const id = url.split('youtu.be/')[1].split('?')[0];\n        embedUrl = 'https://www.youtube.com/embed/' + id;\n      }\n      content = `<iframe src=\"${embedUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    }\n    // Bilibili\n    else if (url.includes('bilibili.com')) {\n      content = `<iframe src=\"${url}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    }\n    // 本地/直链 mp4/webm\n    else {\n      content = `<video src=\"${url}\" controls autoplay style=\"width:100%;height:100%;object-fit:contain;\" playsinline></video>`;\n    }\n    title.textContent = '🎬 ' + project.name + ' — 演示视频';\n  } else if (project.playUrl) {\n    content = `<iframe src=\"${project.playUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    title.textContent = '▶ ' + project.name + ' — 可玩原型';\n  } else {\n    return;\n  }\n\n  body.innerHTML = content;\n  overlay.classList.add('open');\n}","old_string":"function openPlay(projectId) {\n  const project = projects.find(p => p.id === projectId);\n  if (!project || !project.playUrl) return;\n\n  const overlay = document.getElementById('playOverlay');\n  const body = document.getElementById('playBody');\n  const title = document.getElementById('playTitle');\n\n  title.textContent = '▶ ' + project.name;\n  body.innerHTML = `<iframe src=\"${project.playUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n  overlay.classList.add('open');\n}","path":"resume/index.html"}}
