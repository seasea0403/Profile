[2026-07-12T13:21:14.603Z] [TOOL_CALL] {"id":"call_00_yYFyKdjlLuTOZXttEZ7U2326","name":"str_replace_in_file","args":{"new_string":"// ===== 插入磁带 =====\nfunction insertTape(projectId) {\n  if (activeProjectId === projectId) return;\n\n  // 如果已有磁带，先静默清理（不播弹出动画，避免和新插入冲突）\n  if (activeProjectId) {\n    const slot = document.getElementById('tapeSlot');\n    slot.classList.remove('inserted', 'ejecting');\n    document.querySelectorAll('.tape').forEach(t => t.classList.remove('selected'));\n    activeProjectId = null;\n  }\n\n  const project = projects.find(p => p.id === projectId);\n  if (!project) return;\n\n  activeProjectId = projectId;\n\n  const slot = document.getElementById('tapeSlot');\n  const inserted = document.getElementById('insertedTape');\n  inserted.querySelector('.mini-label').style.background = project.color;\n  inserted.querySelector('.mini-name').textContent = project.name;\n\n  document.querySelectorAll('.tape').forEach(t => {\n    t.classList.toggle('selected', t.dataset.projectId === projectId);\n  });\n\n  // 强制重排：先移除 inserted，浏览器确认后再加回 → 过渡动画每次都播放\n  slot.classList.remove('inserted');\n  void slot.offsetWidth;\n  slot.classList.add('inserted');\n\n  // 屏幕内容延迟加载（给槽口动画 400ms 播放时间）\n  setTimeout(() => {\n    const screen = document.getElementById('screen');\n    const screenContent = document.getElementById('screenContent');\n    const screenIdle = document.getElementById('screenIdle');\n\n    screenIdle.style.display = 'none';\n\n    const playBtn = project.playUrl\n      ? `<button class=\"sc-btn\" onclick=\"openPlay('${project.id}')\">▶ 可玩原型</button>`\n      : '';\n    const videoBtn = project.videoUrl\n      ? `<button class=\"sc-btn video-btn\" onclick=\"openPlay('${project.id}','video')\">🎬 演示视频</button>`\n      : '';\n\n    // 轮播幻灯片：封面 + 截图\n    const allSlides = [];\n    if (project.cover) {\n      allSlides.push(`<div class=\"sc-carousel-slide\"><img src=\"${project.cover}\" alt=\"封面\" onerror=\"this.style.display='none';\"></div>`);\n    }\n    project.screenshots.forEach((src, i) => {\n      allSlides.push(`<div class=\"sc-carousel-slide\"><img src=\"${src}\" alt=\"截图${i+1}\" onerror=\"this.style.display='none';\"></div>`);\n    });\n    const slides = allSlides.join('');\n\n    const dots = allSlides.map((_, i) =>\n      `<button class=\"dot${i === 0 ? ' active' : ''}\" data-index=\"${i}\"></button>`\n    ).join('');\n\n    screenContent.innerHTML = `\n      <div class=\"sc-carousel\">\n        <div class=\"sc-carousel-viewport\">\n          <div class=\"sc-carousel-track\">${slides}</div>\n        </div>\n        <button class=\"sc-carousel-arrow prev\">&#8249;</button>\n        <button class=\"sc-carousel-arrow next\">&#8250;</button>\n        <div class=\"sc-carousel-dots\">${dots}</div>\n      </div>\n      <div class=\"sc-info\">\n        <div class=\"sc-project-tag\">${project.tag}</div>\n        <div class=\"sc-project-name\">${project.name}</div>\n        <div class=\"sc-project-desc\">${project.desc}</div>\n        <div class=\"sc-project-highlight\">${project.highlight}</div>\n        <div class=\"sc-actions\">${playBtn}${videoBtn}</div>\n        <div class=\"audio-bars\">\n          <div class=\"bar\"></div><div class=\"bar\"></div><div class=\"bar\"></div>\n          <div class=\"bar\"></div><div class=\"bar\"></div>\n        </div>\n      </div>\n    `;\n\n    initCarousel(screenContent.querySelector('.sc-carousel'));\n\n    screen.classList.add('active');\n    screenContent.classList.add('active');\n  }, 400);\n}","old_string":"// ===== 插入磁带 =====\nfunction insertTape(projectId) {\n  if (activeProjectId === projectId) return;\n  if (activeProjectId) ejectTape(true);\n\n  const project = projects.find(p => p.id === projectId);\n  if (!project) return;\n\n  activeProjectId = projectId;\n\n  const slot = document.getElementById('tapeSlot');\n  const inserted = document.getElementById('insertedTape');\n  inserted.querySelector('.mini-label').style.background = project.color;\n  inserted.querySelector('.mini-name').textContent = project.name;\n\n  document.querySelectorAll('.tape').forEach(t => {\n    t.classList.toggle('selected', t.dataset.projectId === projectId);\n  });\n\n  requestAnimationFrame(() => {\n    slot.classList.add('inserted');\n\n    setTimeout(() => {\n      const screen = document.getElementById('screen');\n      const screenContent = document.getElementById('screenContent');\n      const screenIdle = document.getElementById('screenIdle');\n\n      const playBtn = project.playUrl\n        ? `<button class=\"sc-btn\" onclick=\"openPlay('${project.id}')\">▶ 可玩原型</button>`\n        : '';\n      const videoBtn = project.videoUrl\n        ? `<button class=\"sc-btn video-btn\" onclick=\"openPlay('${project.id}','video')\">🎬 演示视频</button>`\n        : '';\n\n      // 轮播幻灯片：封面 + 截图\n      const allSlides = [];\n      if (project.cover) {\n        allSlides.push(`<div class=\"sc-carousel-slide\"><img src=\"${project.cover}\" alt=\"封面\" onerror=\"this.style.display='none';\"></div>`);\n      }\n      project.screenshots.forEach((src, i) => {\n        allSlides.push(`<div class=\"sc-carousel-slide\"><img src=\"${src}\" alt=\"截图${i+1}\" onerror=\"this.style.display='none';\"></div>`);\n      });\n      const slides = allSlides.join('');\n\n      // 轮播圆点\n      const dots = allSlides.map((_, i) =>\n        `<button class=\"dot${i === 0 ? ' active' : ''}\" data-index=\"${i}\"></button>`\n      ).join('');\n\n      screenContent.innerHTML = `\n        <div class=\"sc-carousel\">\n          <div class=\"sc-carousel-viewport\">\n            <div class=\"sc-carousel-track\">${slides}</div>\n          </div>\n          <button class=\"sc-carousel-arrow prev\">&#8249;</button>\n          <button class=\"sc-carousel-arrow next\">&#8250;</button>\n          <div class=\"sc-carousel-dots\">${dots}</div>\n        </div>\n        <div class=\"sc-info\">\n          <div class=\"sc-project-tag\">${project.tag}</div>\n          <div class=\"sc-project-name\">${project.name}</div>\n          <div class=\"sc-project-desc\">${project.desc}</div>\n          <div class=\"sc-project-highlight\">${project.highlight}</div>\n          <div class=\"sc-actions\">${playBtn}${videoBtn}</div>\n          <div class=\"audio-bars\">\n            <div class=\"bar\"></div><div class=\"bar\"></div><div class=\"bar\"></div>\n            <div class=\"bar\"></div><div class=\"bar\"></div>\n          </div>\n        </div>\n      `;\n\n      // 初始化轮播\n      initCarousel(screenContent.querySelector('.sc-carousel'));\n\n      screen.classList.add('active');\n      screenContent.classList.add('active');\n      screenIdle.style.display = 'none';\n    }, 500);\n  });\n}","path":"index.html"}}
