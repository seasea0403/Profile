[2026-07-12T12:43:45.745Z] [TOOL_CALL] {"id":"call_00_oeslIJlsS8OtUH2UHPSw1626","name":"str_replace_in_file","args":{"new_string":"// ===== 可玩原型 / 视频 =====\n// 视频链接支持三种格式：\n//   1. 本地 mp4/webm 路径: \"Signal/忆波.mp4\"\n//   2. YouTube 链接: \"https://www.youtube.com/watch?v=xxxxx\" 或 \"https://youtu.be/xxxxx\"\n//   3. B站 bvid（纯 ID）: \"BV1xxxxxxxx\" → 自动生成 player.bilibili.com 嵌入\nfunction openPlay(projectId, mode = 'game') {\n  const project = projects.find(p => p.id === projectId);\n  if (!project) return;\n\n  const overlay = document.getElementById('playOverlay');\n  const body = document.getElementById('playBody');\n  const title = document.getElementById('playTitle');\n\n  // 先销毁旧内容（释放 WebGL 内存 / 停止视频）\n  const oldIframe = body.querySelector('iframe');\n  if (oldIframe) {\n    oldIframe.src = 'about:blank';\n    oldIframe.remove();\n  }\n  const oldVideo = body.querySelector('video');\n  if (oldVideo) {\n    oldVideo.pause();\n    oldVideo.src = '';\n    oldVideo.remove();\n  }\n  body.innerHTML = '';\n\n  let content = '';\n\n  if (mode === 'video' && project.videoUrl) {\n    const url = project.videoUrl.trim();\n\n    // B站 bvid（纯 BV 开头、不含 / 和 .）\n    if (/^BV[\\w]+$/.test(url)) {\n      content = `<iframe src=\"//player.bilibili.com/player.html?bvid=${url}&autoplay=0&danmaku=0\" scrolling=\"no\" allow=\"fullscreen\" allowfullscreen></iframe>`;\n      title.textContent = '🎬 ' + project.name + ' — B站演示';\n    }\n    // YouTube\n    else if (url.includes('youtube.com') || url.includes('youtu.be')) {\n      let embedUrl = url;\n      if (url.includes('watch?v=')) {\n        embedUrl = url.replace('watch?v=', 'embed/').split('&')[0];\n      } else if (url.includes('youtu.be/')) {\n        const id = url.split('youtu.be/')[1].split('?')[0];\n        embedUrl = 'https://www.youtube.com/embed/' + id;\n      }\n      content = `<iframe src=\"${embedUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n      title.textContent = '🎬 ' + project.name + ' — YouTube';\n    }\n    // B站完整链接\n    else if (url.includes('bilibili.com')) {\n      content = `<iframe src=\"${url}\" scrolling=\"no\" allow=\"fullscreen\" allowfullscreen></iframe>`;\n      title.textContent = '🎬 ' + project.name + ' — B站演示';\n    }\n    // 本地 mp4/webm\n    else {\n      content = `<video src=\"${url}\" controls autoplay style=\"width:100%;height:100%;object-fit:contain;\" playsinline></video>`;\n      title.textContent = '🎬 ' + project.name + ' — 演示视频';\n    }\n  } else if (project.playUrl) {\n    content = `<iframe src=\"${project.playUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    title.textContent = '▶ ' + project.name + ' — 可玩原型';\n  } else {\n    return;\n  }\n\n  body.innerHTML = content;\n  overlay.classList.add('open');\n}\n\nfunction closePlay() {\n  const overlay = document.getElementById('playOverlay');\n  const body = document.getElementById('playBody');\n\n  // 立刻停止：iframe src 置空 → 触发 WASM 释放 / 视频停止\n  const iframe = body.querySelector('iframe');\n  if (iframe) {\n    iframe.src = 'about:blank';\n    iframe.remove();\n  }\n  const video = body.querySelector('video');\n  if (video) {\n    video.pause();\n    video.src = '';\n    video.remove();\n  }\n  body.innerHTML = '';\n  overlay.classList.remove('open');\n}","old_string":"// ===== 可玩原型 =====\nfunction openPlay(projectId, mode = 'game') {\n  const project = projects.find(p => p.id === projectId);\n  if (!project) return;\n\n  const overlay = document.getElementById('playOverlay');\n  const body = document.getElementById('playBody');\n  const title = document.getElementById('playTitle');\n\n  let content = '';\n\n  if (mode === 'video' && project.videoUrl) {\n    const url = project.videoUrl;\n    // YouTube\n    if (url.includes('youtube.com') || url.includes('youtu.be')) {\n      let embedUrl = url;\n      if (url.includes('watch?v=')) {\n        embedUrl = url.replace('watch?v=', 'embed/').split('&')[0];\n      } else if (url.includes('youtu.be/')) {\n        const id = url.split('youtu.be/')[1].split('?')[0];\n        embedUrl = 'https://www.youtube.com/embed/' + id;\n      }\n      content = `<iframe src=\"${embedUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    }\n    // Bilibili\n    else if (url.includes('bilibili.com')) {\n      content = `<iframe src=\"${url}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    }\n    // 本地/直链 mp4/webm\n    else {\n      content = `<video src=\"${url}\" controls autoplay style=\"width:100%;height:100%;object-fit:contain;\" playsinline></video>`;\n    }\n    title.textContent = '🎬 ' + project.name + ' — 演示视频';\n  } else if (project.playUrl) {\n    content = `<iframe src=\"${project.playUrl}\" allow=\"autoplay; fullscreen\" allowfullscreen></iframe>`;\n    title.textContent = '▶ ' + project.name + ' — 可玩原型';\n  } else {\n    return;\n  }\n\n  body.innerHTML = content;\n  overlay.classList.add('open');\n}\n\nfunction closePlay() {\n  const overlay = document.getElementById('playOverlay');\n  const body = document.getElementById('playBody');\n  overlay.classList.remove('open');\n  // 延迟清空 iframe 防止音频残留\n  setTimeout(() => { body.innerHTML = ''; }, 300);\n}","path":"resume/index.html"}}
